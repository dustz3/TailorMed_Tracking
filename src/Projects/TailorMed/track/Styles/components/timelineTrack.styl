    // Import/Export/Cross Trade Timeline (7 nodes + 2 events) - 獨立樣式
    &.timeline-import_export
      .timeline-visual-container
        .timeline-nodes
          left -16px
          right -16px
          justify-content space-between
        
        .timeline-events
          position absolute
          top 50%
          left -16px
          right -16px
          height 16px
          transform translateY(-50%)
          z-index 1
          
          .timeline-event:nth-child(1)
            left 57.5%
            
          .timeline-event:nth-child(2)
            left 74%
        
        // Import/Export 專用的分段式連接線 (7個節點，6段間距)
        .timeline-horizontal-line
          &::before
            content ''
            position absolute
            top 0
            left 0
            height 100%
