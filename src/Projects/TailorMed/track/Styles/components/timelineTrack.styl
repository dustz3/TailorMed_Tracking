            z-index 3
            
          &::after
            content ''
            position absolute
            top -1px
            left 72%  // 從第6個節點開始
            height 100%
            width 28%  // 剩餘的節點
            background neutral-light
            border 1px solid neutral-light
            z-index 2
            
          // 完成節點線段前的突出部分
          &::before
            // 在 ::before 的基礎上添加突出部分
            box-shadow 10px 0 0 accent-color
            
      // Import/Export/Cross Trade Panel 的 node-circle hover 樣式（與 Domestic 一致）
      .timeline-visual-container .timeline-nodes .timeline-node .node-circle:hover
        transform translate(-50%, -50%) scale(1.1) !important
