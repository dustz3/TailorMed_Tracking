    // Cross Trade Layered (3 layers with alignment)
    &.timeline-cross_trade_layered
      display flex
      flex-direction column
      gap 40px
      
      // Origin 和 Destination 主容器 (100% 寬度)
      .timeline-main-layers
        width 100%
        display flex
