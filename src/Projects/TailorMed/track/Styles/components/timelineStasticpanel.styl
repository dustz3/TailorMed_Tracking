// Timeline Statistics Panel Component
// 時間軸統計面板組件樣式

@import '../variables'

.timeline-stats-panel
  background linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 100%)
  padding 50px 0
  margin 30px 0
  
  .container
    max-width 1200px
    margin 0 auto
    padding 0 20px
    
  .stats-content
    text-align center
    margin-bottom 40px
    
    .stats-title
      font-size 2.2rem
      font-weight 700
      color primary-color
      margin-bottom 15px
      
    .stats-description
      font-size 1rem
      color neutral-gray
      max-width 500px
      margin 0 auto
      line-height 1.6
      
  .stats-grid
    display grid
    grid-template-columns repeat(auto-fit, minmax(250px, 1fr))
    gap 25px
    margin-top 35px
    
  .stat-card
    background base-white
    border-radius 12px
    padding 25px
    box-shadow 0 2px 15px rgba(0, 0, 0, 0.06)
    transition all 0.3s ease
    border 1px solid rgba(0, 0, 0, 0.04)
    text-align center
    
    &:hover
      transform translateY(-3px)
      box-shadow 0 5px 25px rgba(0, 0, 0, 0.1)
      
    .stat-icon
      width 50px
      height 50px
      margin 0 auto 15px auto
      background linear-gradient(135deg, primary-color, accent-color)
      border-radius 50%
      display flex
      align-items center
      justify-content center
      
      img
        width 24px
        height 24px
        filter brightness(0) invert(1)
        
    .stat-content
      .stat-number
        font-size 2rem
        font-weight 700
        color primary-color
        margin-bottom 5px
        line-height 1
        
      .stat-label
        font-size 1rem
        font-weight 600
        color neutral-gray
        margin-bottom 8px
        
      .stat-description
        font-size 0.85rem
        color #888
        line-height 1.4
        margin 0

// Mobile 響應式設計
@media (max-width: 768px)
  .timeline-stats-panel
    padding 35px 0
    margin 20px 0
    
    .container
      padding 0 15px
      
    .stats-content
      margin-bottom 25px
      
      .stats-title
        font-size 1.8rem
        
      .stats-description
        font-size 0.9rem
        
    .stats-grid
      grid-template-columns 1fr
      gap 20px
      margin-top 25px
      
    .stat-card
      padding 20px
      
      .stat-icon
        width 45px
        height 45px
        margin-bottom 12px
        
        img
          width 22px
          height 22px
          
      .stat-content
        .stat-number
          font-size 1.8rem
          margin-bottom 4px
          
        .stat-label
          font-size 0.9rem
          margin-bottom 6px
          
        .stat-description
          font-size 0.8rem

