// Import/Export Timeline 專用樣式
// 7個節點 + 2個事件的國際運輸時間軸

// Gradient Shine 動畫效果 - 用於 Processing 狀態
@keyframes gradientShine
  0%
    left -100%
    opacity 0
  10%
    opacity 1
  90%
    opacity 1
  100%
    left 100%
    opacity 0

// Completion Shine 動畫效果 - 用於完成狀態
@keyframes completionShine
  0%
    left -100%
    opacity 0
  10%
    opacity 1
  90%
    opacity 1
  100%
    left 100%
    opacity 0

// TailorMed Glow 動畫效果 - 用於完成狀態的 mark
@keyframes tailormedGlow
  0%
    filter brightness(0) invert(0)
  25%
    filter brightness(0) invert(0)
  50%
    filter brightness(0) invert(1)
  75%
    filter brightness(0) invert(1)
  100%
    filter brightness(0) invert(0)

// 飛機飄動動畫效果 - 用於 In Transit 狀態
@keyframes planeFloat
  0%
    transform translate(-50%, -50%) translateY(-0.5px)
  25%
    transform translate(-50%, -50%) translateY(-3px)
  50%
    transform translate(-50%, -50%) translateY(-0.5px)
  75%
    transform translate(-50%, -50%) translateY(1.5px)
  100%
    transform translate(-50%, -50%) translateY(-0.5px)

.results-panel
  .timeline-track-container
    .timeline-events
      top 22%
    // Import/Export Timeline 樣式
    &.timeline-import_export
      .timeline-visual-container
        .timeline-nodes
          left -16px
          right -16px
          justify-content space-between
          
               // Import/Export 專用的分段式連接線 (7個節點，6段間距)
               .timeline-horizontal-line
                 &::before
                   content ''
                   position absolute
                   top 0
                   left 0
                   height 100%
                   width 89%  // 調整為 89%
                   background linear-gradient(to right, primary-color, accent-color)
                   border-radius 25px
                   z-index 3
                   
                 &::after
                   content ''
                   position absolute
                   top -1px
                   left 88%  // 從 88% 開始
                   height 100%
                   width 12%  // 剩餘的節點 (12%)
                   background #dfeaf3
                   border 1px solid #dfeaf3
                   z-index 2
            
        // Import/Export 專用的節點樣式
        .timeline-node
          // 節點日期位置調整
          .node-date
            top -60px !important
          // 節點狀態位置調整
          .node-status
            top 30px !important
          // 前5個節點的狀態文字顏色
          &:nth-child(1), &:nth-child(2), &:nth-child(3), &:nth-child(4), &:nth-child(5)
            .node-status
              .status-text
                color primary-color !important
          // 第6個節點 (Processing 狀態) 的 Gradient shine 效果
          &:nth-child(6)
            .node-status
              .status-text
                position relative
                color accent-color !important
                overflow hidden
                
                // 添加 Gradient shine 動畫
                &::before
                  content ''
                  position absolute
                  top 0
                  left -100%
                  width 100%
                  height 100%
                  background linear-gradient(90deg, transparent, rgba(255,255,255,0.8), transparent)
                  animation gradientShine 2s infinite
                  pointer-events none
                  z-index 1
                  border-radius 2px
          // 第7個節點 (Pending 狀態) 的狀態文字顏色
          &:nth-child(7)
            .node-status
              .status-text
                color neutral-light !important
                position static !important
                overflow visible !important
                
                &::before
                  display none !important

