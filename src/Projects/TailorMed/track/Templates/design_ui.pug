doctype html
html(lang="zh-TW")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title TailorMed｜貨件追蹤系統 - Test Version
    link(rel="preconnect", href="https://fonts.googleapis.com")
    link(rel="preconnect", href="https://fonts.gstatic.com", crossorigin)
    link(href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@300;400;500;600;700&display=swap", rel="stylesheet")
    link(rel="stylesheet", href="./css/main.css")
    script(src="./js/config.js")
    script(src="./js/app.js", defer)
  body
    header.site-header
      .container
        .brand
          img.brand-logo(src="./images/logo.png", alt="TailorMed")
        nav.site-nav
          a.nav-link(href="./index.html") Back to Home
          a.nav-link(href="https://tailormed.com.tw", target="_blank", rel="noopener") Back to TailorMed

    section.hero-banner
      .hero-overlay
      .container
        .hero-content
          .hero-text
            h1.hero-title Track Your TailorMed Shipments Anytime
            p.hero-subtitle.hero-subtitle--desktop Use your order number and job ID to review the most recent shipment status available from TailorMed.
            p.hero-subtitle.hero-subtitle--mobile Use your order number and job ID to review the most recent shipment status available from TailorMed.

    section.hero-summary
      //- 1. Shipment Tracking Lookup
      include components/lookupPanel.pug

      //- 2. Latest shipment updates
      include components/resultsPanel.pug

      //- 3. Timeline Components - 可以獨立載入每個組件
      
      //- Import/Ixport Timeline
      include components/timelineImport.pug

      //- Import/Export Timeline
      include components/timelineExport.pug
      
      //- Domestic Timeline
      include components/timelineDomestic.pug
      
      //- Cross Trade Timeline
      include components/timelineCrossTrade.pug
      
      //- Order Completion Timeline
      include components/timelineOrderCompletion.pug
      
      //- 原始完整 Timeline (可選)
      //- include components/timelineTrack.pug

        //- 系統說明文字
        section.system-description
          .container
            .description-content
              .description-header
                h3.description-title TailorMed™ Shipment Tracking Notice｜Cold Chain Dedicated Service
                .urgent-call-icon
                  img(src="./images/urgentCall.png", alt="Urgent Call", width="40", height="40")
          
              p.description-text
                | This tracking platform is exclusively provided by TailorMed for authorized clients to access real-time shipment information. Data is updated daily and accessible across multiple devices and platforms—no software installation required. Clients can securely monitor cold chain shipments anytime, anywhere.
              
              p.description-text
                | To protect the integrity and confidentiality of your shipment data, all queries are access-controlled and transmitted securely. Tracking records are used solely for logistics coordination and customer support purposes and will never be shared with third parties.
          
          p.description-text
            | For questions or urgent inquiries, please contact your project coordinator directly. Contact us at 
            strong +8862-2694-6168 
            | or email 
            strong customer-service@tailormed-intl.com
            | . TailorMed is committed to safeguarding every shipment with reliable systems, transparent tracking, and industry-grade security protocols.


    footer.site-footer
      .container
        p.site-footer__copy © 2025 TailorMed. All Rights Reserved.
