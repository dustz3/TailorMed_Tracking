doctype html
html(lang="zh-TW")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title TailorMed｜貨件追蹤系統 - Test Version
    link(rel="preconnect", href="https://fonts.googleapis.com")
    link(rel="preconnect", href="https://fonts.gstatic.com", crossorigin)
    link(href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@300;400;500;600;700&display=swap", rel="stylesheet")
    link(rel="stylesheet", href="./css/main.css")
    script(src="./js/config.js")
    script(src="./js/app.js", defer)
  body
    header.site-header
      .container
        .brand
          img.brand-logo(src="./images/logo.png", alt="TailorMed")
        nav.site-nav
          a.nav-link(href="./index.html") Back to Home
          a.nav-link(href="https://tailormed.com.tw", target="_blank", rel="noopener") Back to TailorMed

    section.hero-banner
      .hero-overlay
      .container
        .hero-content
          .hero-text
            h1.hero-title Track Your TailorMed Shipments Anytime
            p.hero-subtitle.hero-subtitle--desktop Use your order number and job ID to review the most recent shipment status available from TailorMed.
            p.hero-subtitle.hero-subtitle--mobile Use your order number and job ID to review the most recent shipment status available from TailorMed.

    section.hero-summary
      //- 1. Shipment Tracking Lookup
      include components/lookupPanel.pug

      //- 2. Latest shipment updates
      include components/resultsPanel.pug

      //- 3. Timeline Components - 可以獨立載入每個組件
      
      //- Import/Ixport Timeline
      include components/timelineImport.pug

      //- Import/Export Timeline
      include components/timelineExport.pug
      
      //- Domestic Timeline
      include components/timelineDomestic.pug
      
      //- Cross Trade Timeline
      include components/timelineCrossTrade.pug
      
      //- Order Completion Timeline
      include components/timelineOrderCompletion.pug
      
      //- 原始完整 Timeline (可選)
      //- include components/timelineTrack.pug

    //- 系統說明文字
    section.system-description
      .container
        .description-content
          p.description-text
            | TailorMed's tracking system enables you to check your cargo status online anytime through both mobile and desktop platforms. Our visual timeline interface provides clear shipment progress updates while maintaining strict privacy protection for your sensitive cargo information, ensuring enhanced service quality and customer satisfaction.
          
          p.description-text
            | Both order number and tracking number are required for secure access, ensuring that only authorized parties can view your shipment details. Our dual-authentication system protects your cargo privacy while delivering real-time tracking capabilities.
          
          p.description-text
            | Contact us on 
            strong +8862-2694-6168 
            | or email 
            strong customer-service@tailormed-intl.com

    footer.site-footer
      .container
        p.site-footer__copy © 2025 TailorMed. All Rights Reserved.
