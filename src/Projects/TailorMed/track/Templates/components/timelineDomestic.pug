//- Domestic Timeline Track Component
//- 國內時間軸軌道組件

.timeline-track-panel
  h2.panel-title Domestic 
  
  .timeline-track-container.timeline-domestic
    .timeline-visual-container
      .timeline-horizontal-line
      .timeline-nodes
        .timeline-node.completed(data-step="1")
          .node-circle
          .node-date
            span.month Oct
            span.day 10
          .node-content
            .node-status
              .status-text Order Created
              .status-time 10:16
        .timeline-node.processing(data-step="2")
          .node-circle
          .node-date
            span.month Oct
            span.day 12
          .node-content
            .node-status
              .status-text Shipment Collected
              .status-time Processing...
        .timeline-node.pending(data-step="3")
          .node-circle
          .node-date TBD
          .node-content
            .node-status
              .status-text In Transit
              .status-time --:--
        .timeline-node.pending(data-step="4")
          .node-circle
          .node-date TBD
          .node-content
            .node-status
              .status-text Shipment Delivered
              .status-time --:--
