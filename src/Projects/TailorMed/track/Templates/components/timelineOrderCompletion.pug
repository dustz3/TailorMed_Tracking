//- Order Completion Timeline Track Component
//- 訂單完成時間軸軌道組件

.timeline-track-panel
  h2.panel-title Order Completion Timeline Track
  
  .timeline-track-container.timeline-order_completion
    .track-content
      p 
        | ORDER COMPLETION
        br
        | 3 Nodes
    .timeline-visual-container
      .timeline-horizontal-line
      .timeline-nodes
        .timeline-node.completed(data-step="1")
          .node-circle
          .node-date Oct 13
          .node-status
            .status-text Final Inspection
            .status-time 09:15
        .timeline-node.completed(data-step="2")
          .node-circle
          .node-date Oct 13
          .node-status
            .status-text Quality Approval
            .status-time 11:30
        .timeline-node.completed(data-step="3")
          .order-completion-container
          .node-date Oct 13
          .node-status
            .status-text Order Completed
            .status-time 14:45
