//- Import/Export Timeline 組件
//- 7個節點 + 2個事件的國際運輸時間軸

.timeline-track-container.timeline-import_export.timeline-progress-5
  .timeline-visual-container
    .timeline-horizontal-line
    .timeline-nodes
      .timeline-node.completed(data-step="1")
        .node-circle
        .node-date Oct 10
        .node-status
          .status-text Order Created
          .status-time 10:30
      
      .timeline-node.completed(data-step="2")
        .node-circle
        .node-date Oct 11
        .node-status
          .status-text Shipment Collected
          .status-time 15:20
      
      .timeline-node.completed(data-step="3")
        .node-circle
        .node-date Oct 12
        .node-status
          .status-text Origin Customs Process
          .status-time 09:15
      
      .timeline-node.completed(data-step="4")
        .node-circle
        .node-date Oct 13
        .node-status
          .status-text In Transit
          .status-time 14:30
      
      .timeline-node.processing(data-step="5")
        .node-circle
        .node-date Oct 14
        .node-status
          .status-text Destination Customs Process
          .status-time Processing...
      
      .timeline-node.pending(data-step="6")
        .node-circle
        .node-date TBD
        .node-status
          .status-text Out for Delivery
          .status-time --:--
      
      .timeline-node.pending(data-step="7")
        .node-circle
        .node-date TBD
        .node-status
          .status-text Shipment Delivered
          .status-time --:--
    
    .timeline-events
      .timeline-event(data-event="dry-ice")
        .event-tag
          .event-tag-text Dry ice refilled
            br
            | (Terminal)
      
      .timeline-event(data-event="special-handling" style="display: none;")
        .event-tag
          .event-tag-text Out for Delivery
