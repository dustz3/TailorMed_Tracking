//- Cross Trade Timeline Track Component
//- 跨國貿易時間軸軌道組件

.timeline-track-panel
  h2.panel-title Cross Trade
  
  .timeline-track-container.timeline-cross_trade_layered

    // Origin 和 Destination 容器 (100% 寬度)
    .timeline-main-layers
      // Origin 階段 (綠色，4 節點)
      .timeline-origin-wrapper
        .timeline-layer.timeline-origin-layer.origin-stage
          .timeline-visual-container
            .timeline-horizontal-line
            .timeline-nodes
              .timeline-node.timeline-origin.completed(data-step="1")
                .node-circle
                .node-date Oct 08
                .node-status
                  .status-text Cargo Ready
                  .status-time 15:32
              .timeline-node.timeline-origin.completed(data-step="2")
                .node-circle
                .node-date Oct 09
                .node-status
                  .status-text Port In
                  .status-time 08:22
              .timeline-node.timeline-origin.completed(data-step="3")
                .node-circle
                .node-date Oct 09
                .node-status
                  .status-text On Board
                  .status-time 11:30
              .timeline-node.timeline-origin.completed(data-step="4")
                .node-circle
                .node-date Oct 09
                .node-status
                  .status-text Departure Confirmed
                  .status-time 14:30
      
      // Destination 階段 (藍色，4 節點)
      .timeline-destination-wrapper
        .timeline-layer.timeline-destination-layer.destination-stage
          .timeline-visual-container
            .timeline-horizontal-line
            .timeline-nodes
              .timeline-node.timeline-destination.completed(data-step="7")
                .node-circle
                .node-date Oct 11
                .node-status
                  .status-text Arrival Port
                  .status-time 00:32
              .timeline-node.timeline-destination.completed(data-step="8")
                .node-circle
                .node-date Oct 11
                .node-status
                  .status-text Customs Cleared
                  .status-time 04:25
              .timeline-node.timeline-destination.completed(data-step="9")
                .node-circle
                .node-date Oct 12
                .node-status
                  .status-text Delivery Out
                  .status-time 07:50
              .timeline-node.timeline-destination.completed(data-step="10")
                .node-circle
                .node-date Oct 13
                .node-status
                  .status-text POD
                  .status-time 18:40
    
    // Transit 階段 (橙色，2 節點) - 移到下方
    .timeline-layer.timeline-transit-layer.transit-stage
      .timeline-visual-container
        .timeline-horizontal-line
        .timeline-nodes
          .timeline-node.timeline-transit.completed(data-step="5")
            .node-circle
            .node-status
              .status-text In Transit Start
              .status-time 15:30
          .timeline-node.timeline-transit.completed(data-step="6")
            .node-circle
            .node-status
              .status-text Arrival Notice Issued
              .status-time 05:30
