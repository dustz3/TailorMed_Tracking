// Additional Information Panel
// 額外資訊面板

section.additional-panel
  .container
    .additional-content
      h2.additional-title Additional Information
      p.additional-description Get more details about your shipment and related services.
      
      .additional-grid
        .additional-card
          .card-icon
            img(src="./images/icon-temperature.svg", alt="Temperature Control")
          .card-content
            h3.card-title Temperature Control
            p.card-description Real-time temperature monitoring for cold chain shipments.
            
        .additional-card
          .card-icon
            img(src="./images/icon-security.svg", alt="Security")
          .card-content
            h3.card-title Security Features
            p.card-description Advanced security measures to protect your shipments.
            
        .additional-card
          .card-icon
            img(src="./images/icon-support.svg", alt="Customer Support")
          .card-content
            h3.card-title 24/7 Support
            p.card-description Round-the-clock customer support for all your needs.
            
        .additional-card
          .card-icon
            img(src="./images/icon-notifications.svg", alt="Notifications")
          .card-content
            h3.card-title Smart Notifications
            p.card-description Get instant updates about your shipment status.

