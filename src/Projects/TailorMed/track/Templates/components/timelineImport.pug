//- Import Timeline Track Component
//- 進口時間軸軌道組件

.timeline-track-panel
  h2.panel-title Import
  .timeline-track-container.timeline-import_export.timeline-progress-5
    .track-content
      p 
        | 7 Nodes with 2 Events
    .timeline-visual-container
      .timeline-horizontal-line
      .timeline-nodes
        .timeline-node.completed(data-step="1")
          .node-circle
          .node-date Oct 09
          .node-status
            .status-text Order Created
            .status-time 03:45
        .timeline-node.completed(data-step="2")
          .node-circle
          .node-date Oct 09
          .node-status
            .status-text Shipment Collected
            .status-time 06:10
        .timeline-node.completed(data-step="3")
          .node-circle
          .node-date Oct 10
          .node-status
            .status-text Origin Customs Process
            .status-time 10:38
        .timeline-node.completed(data-step="4")
          .node-circle
          .node-date Oct 11
          .node-status
            .status-text In Transit
            .status-time 08:15
        .timeline-node.processing(data-step="5")
          .node-circle
          .node-date Oct 13
          .node-status
            .status-text Destination Customs Process
            .status-time Processing...
        .timeline-node.pending(data-step="6")
          .node-circle
          .node-date TBD
          .node-status
            .status-text Out for Delivery
            .status-time --:--
        .timeline-node.pending(data-step="7")
          .node-circle
          .node-date TBD
          .node-status
            .status-text Shipment Delivered
            .status-time --:--
      .timeline-events
        .timeline-event(data-event="event-1")
          .event-tag
            .event-tag-text 
              | Dry ice refilled
              br
              | (Terminal)
