//- 節點狀態說明面板
.status-legend-panel
  .panel-title
    h3 節點狀態說明
    p 了解每個時間軸節點狀態的含義
  
  .status-legend-horizontal
    .status-item
      .status-icon.completed
      .status-info
        .status-name 已完成
        .status-desc Completed
    
    .status-item
      .status-icon.processing
      .status-info
        .status-name 處理中
        .status-desc Processing
    
    .status-item
      .status-icon.in-transit
      .status-info
        .status-name 運輸中
        .status-desc In Transit
    
    .status-item
      .status-icon.pending
      .status-info
        .status-name 等待中
        .status-desc Pending
    
    .status-item
      .status-icon.active
      .status-info
        .status-name 進行中
        .status-desc Active
