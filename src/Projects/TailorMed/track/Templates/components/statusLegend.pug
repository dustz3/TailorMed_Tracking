//- 節點狀態說明面板
.status-legend-panel
  .panel-title
    h3 節點狀態說明
    p 了解每個時間軸節點狀態的含義
  
  .status-legend-horizontal
    .status-item.completed-example
      .timeline-node.completed(data-step="1")
        .node-date Oct 09
        .node-circle
        .node-status
          .status-text Completed
          .status-time 12:34
    
    .status-item.processing-example
      .timeline-node.processing(data-step="2")
        .node-date Oct 10
        .node-circle
        .node-status
          .status-text Processing
          .status-time Processing...
    
    .status-item
      .status-icon.in-transit
      .status-info
        .status-name 運輸中
        .status-desc In Transit
    
    .status-item
      .status-icon.pending
      .status-info
        .status-name 等待中
        .status-desc Pending
    
    .status-item
      .status-icon.active
      .status-info
        .status-name 進行中
        .status-desc Active
