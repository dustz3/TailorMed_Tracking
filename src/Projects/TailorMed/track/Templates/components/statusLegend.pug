//- 節點狀態說明面板
.status-legend-panel
  .panel-title
    h3 節點狀態說明
    p 了解每個時間軸節點狀態的含義
  
  .status-legend-grid
    .status-item
      .status-icon.completed
      .status-info
        .status-name 已完成 (Completed)
        .status-desc 此階段已成功完成，貨件已通過此節點
    
    .status-item
      .status-icon.processing
      .status-info
        .status-name 處理中 (Processing)
        .status-desc 此階段正在進行中，貨件目前在此節點處理
    
    .status-item
      .status-icon.in-transit
      .status-info
        .status-name 運輸中 (In Transit)
        .status-desc 貨件正在運輸途中，通常顯示飛機圖示
    
    .status-item
      .status-icon.pending
      .status-info
        .status-name 等待中 (Pending)
        .status-desc 此階段尚未開始，等待前置條件完成
    
    .status-item
      .status-icon.active
      .status-info
        .status-name 進行中 (Active)
        .status-desc 此階段正在進行，類似 Processing 狀態
